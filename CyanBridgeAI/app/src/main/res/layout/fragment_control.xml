<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Status -->
        <com.google.android.material.chip.Chip
            android:id="@+id/status_chip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="○ Disconnected"
            android:textColor="@android:color/white"
            android:layout_marginBottom="12dp" />

        <!-- Device Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/card_background"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HeyCyan Glasses"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <!-- Battery -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical">

                    <ProgressBar
                        android:id="@+id/battery_bar"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp"
                        android:layout_height="8dp"
                        android:layout_weight="1"
                        android:max="100"
                        android:progress="0"
                        android:progressTint="@color/cyan"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/battery_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔋 --%"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Media counts -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/photo_count_text" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0"
                            android:textSize="22sp" android:textStyle="bold" android:textColor="@color/cyan" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Photos" android:textColor="@color/text_secondary" android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/video_count_text" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0"
                            android:textSize="22sp" android:textStyle="bold" android:textColor="@color/cyan" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Videos" android:textColor="@color/text_secondary" android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/audio_count_text" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0"
                            android:textSize="22sp" android:textStyle="bold" android:textColor="@color/cyan" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Audio" android:textColor="@color/text_secondary" android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Refresh / Sync -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginTop="12dp">
                    <Button android:id="@+id/btn_refresh" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="↻ Refresh" android:layout_marginEnd="8dp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
                    <Button android:id="@+id/btn_sync_time" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="⏱ Sync Time"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- AI Provider -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="AI PROVIDER" android:textColor="@color/text_secondary"
            android:textSize="11sp" android:letterSpacing="0.1" android:layout_marginBottom="8dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp">
            <Button android:id="@+id/btn_gemini" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:text="🔷 Gemini" android:layout_marginEnd="6dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
            <Button android:id="@+id/btn_openai" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:text="🟢 ChatGPT" android:layout_marginEnd="6dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
            <Button android:id="@+id/btn_claude" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:text="🟠 Claude"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
        </LinearLayout>

        <!-- Capture Controls -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="CAPTURE" android:textColor="@color/text_secondary"
            android:textSize="11sp" android:letterSpacing="0.1" android:layout_marginBottom="8dp" />

        <GridLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:columnCount="2" android:rowCount="2" android:layout_marginBottom="16dp">

            <Button android:id="@+id/btn_photo"
                android:layout_width="0dp" android:layout_height="80dp"
                android:layout_columnWeight="1" android:layout_margin="4dp"
                android:text="📷  Photo"
                android:backgroundTint="@color/cyan"
                android:textColor="@color/background" />

            <Button android:id="@+id/btn_video"
                android:layout_width="0dp" android:layout_height="80dp"
                android:layout_columnWeight="1" android:layout_margin="4dp"
                android:text="🎬  Video"
                android:backgroundTint="@color/danger" />

            <Button android:id="@+id/btn_audio"
                android:layout_width="0dp" android:layout_height="80dp"
                android:layout_columnWeight="1" android:layout_margin="4dp"
                android:text="🎙️  Audio"
                android:backgroundTint="@color/warning" />

            <Button android:id="@+id/btn_ai_image"
                android:layout_width="0dp" android:layout_height="80dp"
                android:layout_columnWeight="1" android:layout_margin="4dp"
                android:text="✨  AI Image"
                android:backgroundTint="@color/purple" />
        </GridLayout>

    </LinearLayout>
</ScrollView>
